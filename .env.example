# Copy this file to .env and fill in your key(s)

# Which provider to use: "claude" or "gemini"
PROVIDER=claude

# Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Where Obsidian notes are written (open this folder as a vault in Obsidian)
VAULT_PATH=./vault

# Server port
PORT=3210
